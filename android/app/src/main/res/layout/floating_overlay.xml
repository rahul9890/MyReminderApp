<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_card_bg"
    android:padding="16dp"
    android:elevation="10dp">

    <!-- Header: title + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Reminders"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#222222"/>

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#FF5252"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp"/>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/todo_text_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tick_1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="18sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/todo_text_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tick_2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="18sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/todo_text_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tick_3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="✓"
            android:textSize="18sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/no_todos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All caught up!"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone"/>

</LinearLayout>
